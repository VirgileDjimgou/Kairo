# ───────────────────────────────────────────────────────────────────────────────
# Kairo — Production Environment Variables
# ───────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.production.example .env
#
# All services (api, worker) read from the same .env file.
# ───────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=OrgMind AI
APP_ENV=production
APP_DEBUG=false

# The public URL where the app is reachable (used by CORS and redirects).
# If using Cloudflare Tunnel, use your tunnel hostname:
#   APP_BASE_URL=https://orgmind.yourdomain.com
APP_BASE_URL=http://localhost

# Must point to the API endpoint the browser will call.
# For same-origin proxy (nginx/Caddy):  /api/v1
# For separate subdomain:               https://api.orgmind.yourdomain.com/api/v1
API_BASE_URL=http://localhost/api/v1

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins (the browser's origin).
# Must match the APP_BASE_URL the browser sees.
CORS_ORIGINS=["http://localhost"]

# ── Security — MUST change in production ──────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=orgmind
POSTGRES_USER=orgmind
# Change this to a strong password
POSTGRES_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql+psycopg://orgmind:change-me-to-a-strong-password@postgres:5432/orgmind

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ─────────────────────────────────────────────────────────────────────
# Change both credentials
MINIO_ROOT_USER=orgmind
MINIO_ROOT_PASSWORD=change-me-to-a-strong-password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET_DOCUMENTS=documents

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=orgmind_document_chunks

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_PROVIDER_KIND=ollama
EMBEDDING_PROVIDER_KIND=ollama
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_COMPATIBLE_API_KEY=lm-studio
OPENAI_COMPATIBLE_LLM_MODEL=zai-org/glm-4.7-flash
OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LLM_REQUEST_TIMEOUT_SECONDS=120
RAG_CANDIDATE_MULTIPLIER=5
RAG_LANGUAGE_BOOST=0.15
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1024

# ── Optional notification delivery ────────────────────────────────────────────
# SMTP enables identity email plus the live email operator path.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Telegram enables the live Telegram operator path via the Bot API.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# WhatsApp enables the live operator WhatsApp path through a gateway contract
# that accepts POST {base_url}/messages with Bearer auth.
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=

# Shared secret for provider-side delivery reconciliation callbacks.
# Providers or gateway bridges must send it in the X-Kairo-Notification-Token header.
NOTIFICATION_RECONCILIATION_CALLBACK_TOKEN=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# For production, this should be a relative path (same-origin proxy) or the
# full API URL if using a separate subdomain.
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=OrgMind AI

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt,md,csv,png,jpg,jpeg,webp

# ── Ingestion worker ──────────────────────────────────────────────────────────
INGESTION_CHUNK_SIZE=800
INGESTION_CHUNK_OVERLAP=100
INGESTION_AUTO_ENQUEUE=true

# ── Embeddings / Qdrant indexing ──────────────────────────────────────────────
EMBEDDING_DIMENSIONS=768
EMBEDDING_REQUEST_TIMEOUT_SECONDS=120
INDEXING_AUTO_ENABLED=true
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.65
RAG_RERANK_ENABLED=true
RAG_HYBRID_SEARCH=true
CONVERSATION_MAX_HISTORY=20
CONVERSATION_RETENTION_DAYS=30

# ── Cloudflare Tunnel (leave blank to disable) ────────────────────────────────
# Get a tunnel token from https://dash.cloudflare.com/ → Zero Trust → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
