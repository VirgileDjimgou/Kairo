# Project
APP_NAME=OrgMind AI
APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security — CHANGE in production
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_DB=orgmind
POSTGRES_USER=orgmind
POSTGRES_PASSWORD=orgmind_dev_password
DATABASE_URL=postgresql+psycopg://orgmind:orgmind_dev_password@postgres:5432/orgmind

# Database (test)
TEST_DATABASE_URL=postgresql+psycopg://orgmind:orgmind_dev_password@localhost:5432/orgmind_test

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=orgmind
MINIO_ROOT_PASSWORD=orgmind_dev_password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET_DOCUMENTS=documents

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=orgmind_document_chunks

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=bge-m3
LLM_PROVIDER_KIND=ollama
EMBEDDING_PROVIDER_KIND=ollama
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_COMPATIBLE_API_KEY=lm-studio
OPENAI_COMPATIBLE_LLM_MODEL=zai-org/glm-4.7-flash
OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LLM_REQUEST_TIMEOUT_SECONDS=120
RAG_CANDIDATE_MULTIPLIER=5
RAG_LANGUAGE_BOOST=0.15
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1024

# Optional notification delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
NOTIFICATION_RECONCILIATION_CALLBACK_TOKEN=

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=OrgMind AI

# Upload limits
MAX_UPLOAD_MB=50
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt,md,csv,png,jpg,jpeg,webp

# Ingestion worker
INGESTION_CHUNK_SIZE=800
INGESTION_CHUNK_OVERLAP=100
INGESTION_AUTO_ENQUEUE=true

# Embeddings / Qdrant indexing
EMBEDDING_DIMENSIONS=1024
EMBEDDING_REQUEST_TIMEOUT_SECONDS=120
INDEXING_AUTO_ENABLED=true
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.65
RAG_RERANK_ENABLED=true
RAG_HYBRID_SEARCH=true
CONVERSATION_MAX_HISTORY=20
CONVERSATION_RETENTION_DAYS=30

# Cloudflare Tunnel (leave blank to disable)
CLOUDFLARE_TUNNEL_TOKEN=
