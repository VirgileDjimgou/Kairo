# ───────────────────────────────────────────────────────────────────────────────
# Cloudflare Tunnel Configuration Sample
# ───────────────────────────────────────────────────────────────────────────────
#
# Two approaches to set up a tunnel:
#
#   Option A — Docker (recommended)
#     Set CLOUDFLARE_TUNNEL_TOKEN in your .env file, then run:
#       docker compose --profile tunnel up -d
#
#   Option B — Standalone cloudflared (no Docker)
#     1. Install cloudflared: https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install/
#     2. Authenticate:        cloudflared tunnel login
#     3. Create a tunnel:     cloudflared tunnel create kairo-local
#     4. Copy the generated  ~/.cloudflared/<tunnel-id>.json  to this machine
#     5. Use this config file:
#        cloudflared tunnel --config infra/cloudflare/config.yml.example run
#
# ───────────────────────────────────────────────────────────────────────────────

tunnel: kairo-local
credentials-file: /home/USER/.cloudflared/kairo-local.json

ingress:
  # Production setup — single domain with reverse proxy
  # The reverse proxy (Caddy/Nginx) serves the frontend at / and proxies
  # /api/* to the backend. This is the recommended approach.
  - hostname: orgmind.yourdomain.com
    service: http://localhost:80

  # Alternative — separate subdomains (no reverse proxy needed)
  # - hostname: app.yourdomain.com
  #   service: http://localhost:80
  # - hostname: api.yourdomain.com
  #   service: http://localhost:8000

  # Development setup — direct to Vite dev server and API
  # - hostname: dev.yourdomain.com
  #   service: http://localhost:5173
  # - hostname: api.dev.yourdomain.com
  #   service: http://localhost:8000

  # Catch-all — required by cloudflared, returns 404 for unmatched routes
  - service: http_status:404

# ── Security rules ────────────────────────────────────────────────────────────
# Never expose these ports through the tunnel. They must remain private:
#
#   Port   Service         Why
#   ─────  ──────────────  ─────────────────────────────────────────────────
#   5432   PostgreSQL      Direct database access = full data breach
#   6379   Redis            Can lead to data exposure or RCE
#   6333   Qdrant           Vector DB with all document contents
#   6334   Qdrant gRPC      Internal gRPC interface
#   9000   MinIO (S3 API)   All uploaded documents
#   9001   MinIO Console    Admin UI for object storage
#   11434  Ollama           Unauthenticated model access
#
# If you must access these for remote administration, use SSH tunneling
# or Cloudflare Access with strong authentication — never expose directly.
