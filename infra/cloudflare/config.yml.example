# Cloudflare Tunnel Configuration Sample
#
# Copy this to ~/.cloudflared/config.yml (or use the tunnel token approach in docker-compose).
# See: https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/

tunnel: kairo-local
credentials-file: /home/USER/.cloudflared/kairo-local.json

ingress:
  # Route the frontend
  - hostname: orgmind.example.com
    service: http://localhost:5173

  # Route the API (or use a single domain with a reverse proxy)
  - hostname: api.orgmind.example.com
    service: http://localhost:8000

  # Catch-all (required by cloudflared)
  - service: http_status:404

# Security note: Never expose these ports through the tunnel:
#   - 5432 (PostgreSQL)
#   - 6379 (Redis)
#   - 6333 (Qdrant)
#   - 9000/9001 (MinIO)
#   - 11434 (Ollama)
